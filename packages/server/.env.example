# Database
# For local development:
DATABASE_URL="file:./prisma/dev.db"
# For production (Render with persistent disk):
# DATABASE_URL="file:/var/data/db.sqlite"
# For production (Fly.io with volume):
# DATABASE_URL="file:/data/db.sqlite"

# JWT Secret (change this in production!)
JWT_SECRET="your-secret-key-change-in-production"

# Node Environment
NODE_ENV="development"

# Client URL (for email links)
CLIENT_URL="http://localhost:5173"

# DB sync from prod (used by scripts/sync-db-from-prod.sh)
# VPS_HOST="deploy@your-server-ip"
# VPS_DB="/var/data/db.sqlite"   # optional, this is the default
# SSH_KEY="~/.ssh/id_rsa"        # optional, this is the default

# Email Configuration (optional)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USER="your-email@example.com"
# SMTP_PASS="your-password"
