# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Shell scripts should always use LF
*.sh text eol=lf

# Windows scripts should use CRLF
*.ps1 text eol=crlf
*.bat text eol=crlf

# Explicitly declare files that should not be normalized
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.db binary
